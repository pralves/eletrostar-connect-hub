# ── SMTP (Hostinger) ────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=pralves@eletrostarsoft.com.br
SMTP_PASS=coloque_a_senha_aqui
# Destinatário interno das mensagens do formulário
CONTACT_TO=pralves@eletrostarsoft.com.br
