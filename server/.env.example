# ── Servidor ────────────────────────────────────────────────
PORT=3001
# Origem permitida para CORS (URL do frontend Vite). Use vírgula para múltiplas.
CORS_ORIGIN=http://localhost:8080

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=coloque_a_url_aqui
SUPABASE_SERVICE_ROLE_KEY=coloque_a_service_role_key_aqui
