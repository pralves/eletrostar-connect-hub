{
  "name": "eletrostar-connect-hub-server",
  "version": "1.0.0",
  "description": "API Node/Express (Clean Architecture) do site EletroStar — contato + persistência no Supabase.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
